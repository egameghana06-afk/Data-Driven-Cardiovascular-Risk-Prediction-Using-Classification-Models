<!DOCTYPE html>
<html>
<head>
    <title>Heart Risk Predictor</title>
    <style>
        body {
            font-family: Arial;
            background: #f4f4f4;
            text-align: center;
        }
        form {
            background: white;
            padding: 20px;
            margin: 50px auto;
            width: 300px;
            border-radius: 10px;
        }
        input {
            margin: 10px;
            padding: 8px;
            width: 80%;
        }
        button {
            padding: 10px;
            background: #28a745;
            color: white;
            border: none;
        }
    </style>
</head>
<body>

<h2>🫀 Cardiovascular Risk Prediction</h2>

<form action="/predict" method="post">
    <input type="text" name="age" placeholder="Age"><br>
    <input type="text" name="bp" placeholder="Blood Pressure"><br>
    <input type="text" name="chol" placeholder="Cholesterol"><br>
    <button type="submit">Predict</button>
</form>

<h3>{{ prediction_text }}</h3>

</body>
</html>
